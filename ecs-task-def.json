{
  "family": "flask-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::637675605421:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "flask-container",
      "image": "637675605421.dkr.ecr.us-east-1.amazonaws.com/my-flask-app:latest",
      "portMappings": [
        { "containerPort": 5000 }
      ]
    }
  ]
}
 
